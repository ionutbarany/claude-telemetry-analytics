# Copy to .env and adjust for your local setup.
# Never commit real credentials.

# PostgreSQL database name
POSTGRES_DB=telemetry

# PostgreSQL role used by the app and Compose
POSTGRES_USER=telemetry

# Local-only password — change before any shared or production use
POSTGRES_PASSWORD=telemetry_dev_password

# SQLAlchemy connection string (psycopg3 driver)
DATABASE_URL=postgresql+psycopg://telemetry:telemetry_dev_password@localhost:5432/telemetry

# Bind address for the FastAPI server
API_HOST=0.0.0.0

# Port for the FastAPI server
API_PORT=8000

# Port for the Streamlit dashboard
STREAMLIT_PORT=8501

# Logging verbosity: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
